/tmp/openclaw/openclaw-*.log
/var/log/openclaw/archive-logs.log
{
  daily
  rotate 7
  compress
  delaycompress
  missingok
  notifempty
  copytruncate
  su root root
}

/var/log/openclaw/archive/*.log
{
  daily
  rotate 3
  compress
  delaycompress
  missingok
  notifempty
  copytruncate
  su root root
}
