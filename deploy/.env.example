# AWS
AWS_REGION=REPLACE_ME

# OpenClaw
OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-6
OPENCLAW_MODEL_FAST=anthropic/claude-haiku-4-5
OPENCLAW_MODEL_DEEP=anthropic/claude-opus-4-6
OPENCLAW_PORT=18789
OPENCLAW_BIND_MODE=loopback
CLAWHUB_SKILLS=asana,summarize,youtube-watcher,self-improving-agent,notion,sentry-observability
OPENCLAW_SKILLS=coding-agent,gh-issues,github,weather

# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_APP_TOKEN=xapp-REPLACE_ME
SLACK_ALERT_USER_ID=REPLACE_ME
SLACK_ALLOWED_USER_IDS=REPLACE_ME,REPLACE_ME
SLACK_MISSED_MESSAGES_WINDOW_MINUTES=30
SLACK_MISSED_MESSAGES_MAX_ITEMS=20

# Skill credentials
ASANA_PERSONAL_ACCESS_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
NOTION_API_KEY=

# SSH access
KEY_PAIR_NAME=openclaw-admin
SSH_ACCESS_HOSTNAME=ec2-203-0-113-10.compute.amazonaws.com

# Host alert thresholds
HOST_ALERT_MEM_AVAILABLE_PCT=10
HOST_ALERT_DISK_USED_PCT=85

# Logging and archives
S3_ARCHIVE_BUCKET=replace-me
S3_ARCHIVE_PREFIX=openclaw-prod-1
LOCAL_ARCHIVE_RETENTION_DAYS=7

# MCP/API
OPENCLAW_MCP_PLUGIN_ENABLED=true
ASANA_MCP_ENABLED=true
ASANA_MCP_URL=https://mcp.asana.com/v2/mcp
