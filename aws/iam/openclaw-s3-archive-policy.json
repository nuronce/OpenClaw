{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArchiveBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::REPLACE_ME_BUCKET"
    },
    {
      "Sid": "ArchiveObjectReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::REPLACE_ME_BUCKET/*"
    }
  ]
}
